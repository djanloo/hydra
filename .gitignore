# -----------------------------------------------------------------------
# HydraFERS — .gitignore
# -----------------------------------------------------------------------

# CMake build directories (all presets)
build/
build-vs/
build-vs-debug/
build-debug/
build-mingw/
build-skbuild/
CMakeFiles/
CMakeCache.txt
cmake_install.cmake
CTestTestfile.cmake
*.sln
*.vcxproj
*.vcxproj.filters
*.vcxproj.user
*.suo
*.user
.vs/
out/

# CMake generated files
_deps/
*.cmake
!cmake/mingw-toolchain.cmake   # keep the vendored toolchain

# Python packaging / build artefacts
dist/
*.egg-info/
*.egg
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.dylib
*.dll
# Compiled pyfers extension (generated by build; not committed)
src/pyfers*.pyd
src/pyfers*.so

# scikit-build-core artefacts
_skbuild/
*.whl

# Virtual environments
.venv/
venv/
env/
.env

# Editors & IDEs
.vscode/settings.json
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
desktop.ini

# PyInstaller
*.spec
dist_standalone/

# Test / coverage
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage
coverage.xml

# Log and data files produced at runtime
logs/
*.log
data/
run*/
*.yaml.bak

# Windows installer artefacts
*.msi
*.exe
NSIS/

# Documentation build
docs/_build/
docs/site/
